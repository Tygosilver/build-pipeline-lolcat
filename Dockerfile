# Базовый образ: минимальная стабильная версия Debian (slim-вариант для уменьшения размера)
FROM debian:stable-slim

# Переменная окружения для автоматического принятия лицензионных соглашений
# без интерактивного ввода при установке пакетов
ENV DEBIAN_FRONTEND=noninteractive

# Директория для кэша ccache — ускоряет повторные сборки за счёт кэширования объектных файлов
ENV CCACHE_DIR=/tmp/ccache

# Добавление пути к ccache в начало переменной PATH
# Это обеспечивает автоматический перехват вызовов компилятора (gcc) через ccache
ENV PATH=/usr/lib/ccache:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Установка всех необходимых инструментов в один слой RUN для оптимизации размера образа
# Флаг --no-install-recommends уменьшает размер образа, исключая рекомендуемые, но не обязательные пакеты
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Базовые инструменты разработки:
    # - build-essential: мета-пакет, включающий gcc, g++, make, libc-dev
    build-essential \
    # Система контроля версий для получения номера ревизии из истории коммитов
    git \
    # Инструменты для измерения покрытия кода тестами (gcov + фронтенд lcov)
    lcov \
    # Кэширование компиляции — ускоряет повторные сборки одинакового кода
    ccache \
    # Интерпретатор Ruby и полный набор пакетов для работы с утилитой fpm
    ruby-full \
    # Утилита для определения типа файлов (используется для проверки отладочных символов)
    file \
    # Утилита для более коректной работы с числами с плавающей точкой, используется в сравнении регрессии покрытия во время использования режима "coverage"
    bc\
    # Утилиты для работы с DEB-пакетами (требуются fpm для корректной генерации .deb)
    dpkg-dev && \
    # Установка fpm — универсальной утилиты для создания deb/rpm пакетов одной командой
    # Флаг --no-document ускоряет установку, пропуская документацию
    gem install --no-document fpm && \
    # Очистка кэша пакетного менеджера apt для уменьшения размера образа
    apt-get clean && \
    # Удаление временных файлов списков пакетов (не нужны после установки)
    rm -rf /var/lib/apt/lists/*

# Установка рабочей директории внутри контейнера
WORKDIR /work

# Команда по умолчанию — запуск bash
CMD ["/bin/bash"]